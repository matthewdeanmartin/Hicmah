<?xml version="1.0"?>
<configuration>
    <!--
    
    Verbose Trace with DebugView can turn a 1/2 second method into a 17 sec method.
    
    TraceSwitch and SourceSwitch take the same levels, except SourceSwitch takes more including ActivityTracing
    
    -->
    
