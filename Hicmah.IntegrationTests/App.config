        <switches>
            --><!--For TraceSwitch, 0,1,2,3, and 4 correspond Off, Error, Warning, Info, and Verbose, ActivityTracing respectively.--><!--
            --><!-- You can trace activity or you can trace Info/Warn/Verbose on a single listener but not both
